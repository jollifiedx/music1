# ---- dependencies ----
/node_modules
/.pnp
.pnp.js
.yarn/*

# ---- next.js / build output ----
/.next/
/out/
/build
/dist
*.tsbuildinfo
next-env.d.ts.timestamp

# ---- environment & secrets (NEVER commit) ----
# Ignore every .env variant (these can hold API keys / tokens)…
.env
.env.*
# …but keep the safe, secret-free template tracked.
!.env.example

# ---- logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- hosting / deploy ----
.vercel
.netlify

# ---- editor / OS cruft ----
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.pem
